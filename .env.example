# =============================================================================
# Enterprise Real-Time Fraud Detection Platform - Environment Template
# =============================================================================
# Copy this file to .env for local development only.
# Never commit .env or any file containing real credentials.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Spark / Hadoop
# -----------------------------------------------------------------------------
SPARK_MASTER=local[*]
SPARK_APP_NAME=EnterpriseFraudDetection
HADOOP_HOME=/path/to/hadoop
HADOOP_BIN_PATH=/path/to/hadoop/bin

# -----------------------------------------------------------------------------
# Kafka / Confluent Cloud
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=fraud.transactions.raw
KAFKA_API_KEY=replace-with-confluent-api-key
KAFKA_API_SECRET=replace-with-confluent-api-secret

# -----------------------------------------------------------------------------
# Delta Lake / Local Data Paths
# -----------------------------------------------------------------------------
DELTA_LAKE_PATH=./data/bronze
SPARK_WAREHOUSE_DIR=./spark-warehouse

# -----------------------------------------------------------------------------
# Databricks Workspace / SQL Warehouse
# -----------------------------------------------------------------------------
DATABRICKS_HOST=https://replace-with-workspace.cloud.databricks.com
DATABRICKS_TOKEN=replace-with-databricks-token
DATABRICKS_SERVER_HOSTNAME=replace-with-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/replace-with-warehouse-id
DATABRICKS_ACCESS_TOKEN=replace-with-databricks-token
DATABRICKS_CATALOG=fraud_platform
DATABRICKS_SCHEMA=gold
DATABRICKS_BATCH_JOB_ID=0
DATABRICKS_STREAMING_JOB_ID=0

# -----------------------------------------------------------------------------
# AWS / S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=replace-with-s3-bucket

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
DBT_PROFILES_DIR=./fraud_gold/profiles
DBT_TARGET=dev

# -----------------------------------------------------------------------------
# Airflow Local Development
# -----------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=replace-with-generated-fernet-key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=replace-with-local-admin-password

# -----------------------------------------------------------------------------
# Streamlit Community Cloud
# -----------------------------------------------------------------------------
# Add these same Databricks values to Streamlit app secrets instead of uploading
# a .env file when deploying to Streamlit Community Cloud.
STREAMLIT_SERVER_HEADLESS=true
